# Live deploy credentials for https://demo.imrv.netzerolabs.io
#
# Copy to role_credentials.railway-live.yaml (gitignored) and fill in real
# passwords. The local-docker file (role_credentials.yaml) keeps default
# sample-DB seeds; this overrides for the live target only.
#
# Loaded automatically when running `--target=railway-live` if present.

Administrator:
  email: Administrator
  password: <fill-in-live-admin-password>

# Add other roles as needed for live testing:
# Adaptation Submitter:
#   email: ...
#   password: ...
